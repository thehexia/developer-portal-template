# Development Dockerfile — hot-reloadable, with TechDocs local generator support.
# Source code is NOT baked in; mount it via docker-compose volumes.
# node_modules are installed here so the image layer is cached between restarts.

FROM node:22-bullseye-slim

# ── System dependencies ──────────────────────────────────────────────────────
# make/g++/python3 are required to build native Node addons (better-sqlite3,
# isolated-vm, etc.).  python3-venv + pip are for the TechDocs mkdocs generator.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 python3-pip python3-venv \
        make g++ git curl \
    && rm -rf /var/lib/apt/lists/*

# ── TechDocs MkDocs generator ────────────────────────────────────────────────
# Required when techdocs.generator.runIn is set to 'local'.
ENV VIRTUAL_ENV=/opt/venv
RUN python3 -m venv $VIRTUAL_ENV
ENV PATH="$VIRTUAL_ENV/bin:$PATH"
RUN pip3 install mkdocs-techdocs-core

# ── Node / Yarn ──────────────────────────────────────────────────────────────
RUN corepack enable

WORKDIR /app

# Copy Yarn configuration so corepack knows which Yarn version to use.
COPY .yarnrc.yml yarn.lock ./
COPY .yarn/releases/ ./.yarn/releases/

# Copy workspace manifests — enough for yarn to resolve the dependency graph.
COPY package.json ./
COPY packages/app/package.json     ./packages/app/
COPY packages/backend/package.json ./packages/backend/

# Create an empty plugins directory so the "plugins/*" workspace glob is satisfied.
RUN mkdir -p plugins

# Install all dependencies.  The resulting node_modules stay inside the image
# layer; only source files are overlaid by volume mounts at runtime.
RUN yarn install

# The container is started by docker-compose with the appropriate command
# (yarn workspace app start / yarn workspace backend start).
